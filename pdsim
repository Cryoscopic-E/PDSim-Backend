#!/bin/bash

# Configuration
PDSIM_SERVER_DIR="./"
EXAMPLES_DIR="$PDSIM_SERVER_DIR/examples/pddl"
ENTRY_POINT="$PDSIM_SERVER_DIR/src/main.py"
CONDA_ENV="pdsim"

# Help function
show_help() {
    echo "Usage: ./pdsim <command> [args]"
    echo ""
    echo "Commands:"
    echo "  run <example_name>   Run a PDSim example (e.g., 'blocks', 'sokoban')"
    echo "  list                 List available examples"
    echo "  help                 Show this help message"
}

# Check if PDSimServer directory exists
if [ ! -d "$PDSIM_SERVER_DIR" ]; then
    echo "Error: Directory '$PDSIM_SERVER_DIR' not found. Please run this script from the project root."
    exit 1
fi

# Main logic
case "$1" in
    run)
        EXAMPLE_NAME="$2"
        if [ -z "$EXAMPLE_NAME" ]; then
            echo "Error: Missing example name."
            show_help
            exit 1
        fi

        EXAMPLE_PATH="$EXAMPLES_DIR/$EXAMPLE_NAME"
        
        # Check if example exists
        if [ ! -d "$EXAMPLE_PATH" ]; then
            echo "Error: Example '$EXAMPLE_NAME' not found in '$EXAMPLES_DIR'."
            echo "Available examples:"
            ls "$EXAMPLES_DIR"
            exit 1
        fi

        DOMAIN_FILE="$EXAMPLE_PATH/domain.pddl"
        PROBLEM_FILE="$EXAMPLE_PATH/problem.pddl"

        # Check if PDDL files exist
        if [ ! -f "$DOMAIN_FILE" ] || [ ! -f "$PROBLEM_FILE" ]; then
            echo "Error: 'domain.pddl' or 'problem.pddl' not found in '$EXAMPLE_PATH'."
            exit 1
        fi

        echo "Starting PDSim with example: $EXAMPLE_NAME"
        echo "Domain: $DOMAIN_FILE"
        echo "Problem: $PROBLEM_FILE"
        echo "Environment: $CONDA_ENV"
        echo "----------------------------------------"

        # Execute using conda run
        # We assume 'conda' is in the PATH
        if command -v conda &> /dev/null; then
             conda run -n "$CONDA_ENV" --no-capture-output python "$ENTRY_POINT" --domain "$DOMAIN_FILE" --problem "$PROBLEM_FILE"
        else
            echo "Warning: 'conda' command not found. Trying to run with python directly (ensure venv is active)."
            python3 "$ENTRY_POINT" --domain "$DOMAIN_FILE" --problem "$PROBLEM_FILE"
        fi
        ;;

    list)
        echo "Available examples:"
        if [ -d "$EXAMPLES_DIR" ]; then
            ls -1 "$EXAMPLES_DIR"
        else
            echo "Examples directory not found."
        fi
        ;;

    help|*)
        show_help
        ;;
esac
